# ════════════════════════════════════════════
# 沈航智学 AeroTutor — Streamlit Secrets
# ════════════════════════════════════════════
# 本地开发：修改此文件即可，Streamlit 会自动读取
# Streamlit Cloud：在 App Settings → Secrets 中粘贴此内容

LLM_BASE_URL = "https://api.deepseek.com/v1"
LLM_API_KEY = "sk-your-deepseek-api-key"
LLM_MODEL = "deepseek-chat"

# 可选：如需使用 API 端 Embedding（默认用本地模型）
# EMBEDDING_PROVIDER = "local"
# EMBEDDING_MODEL = "all-MiniLM-L6-v2"
# EMBEDDING_API_KEY = ""
# EMBEDDING_BASE_URL = ""
